{
    "name": "AI Page Content Generator",
    "slug": "content-creator",
    "version": "2.0.0",
    "description": "Genera contenuti completi di pagina (body HTML) con AI: prodotti, servizi, categorie, articoli",
    "icon": "document-duplicate",
    "color": "teal",
    "menu_order": 25,
    "requires": {
        "php": ">=8.0",
        "credits": true,
        "services": ["ai", "scraper"]
    },
    "credits": {
        "scrape_url": 1,
        "ai_generate": 3
    },
    "settings_groups": {
        "ai_config": {
            "label": "Configurazione AI",
            "icon": "sparkles",
            "description": "Provider e modello AI per questo modulo",
            "order": 0
        },
        "general": {
            "label": "Impostazioni Generali",
            "icon": "cog",
            "description": "Impostazioni predefinite per la generazione contenuti",
            "order": 1,
            "collapsed": false
        },
        "content_length": {
            "label": "Lunghezza Contenuto",
            "icon": "document-text",
            "description": "Numero minimo di parole per tipo di contenuto",
            "order": 2,
            "collapsed": false
        },
        "image_config": {
            "label": "Generazione Immagini",
            "icon": "photo",
            "description": "Impostazioni per la generazione immagini AI (virtual try-on / staging)",
            "order": 3,
            "collapsed": false
        },
        "costs": {
            "label": "Costi Operazioni",
            "icon": "currency-euro",
            "description": "Crediti consumati per ogni operazione",
            "order": 99,
            "collapsed": true
        }
    },
    "settings": {
        "ai_provider": {
            "type": "select",
            "label": "Provider AI",
            "description": "Provider AI per questo modulo",
            "default": "global",
            "admin_only": true,
            "group": "ai_config",
            "options": [
                {"value": "global", "label": "Usa impostazione globale"},
                {"value": "anthropic", "label": "Anthropic (Claude)"},
                {"value": "openai", "label": "OpenAI (GPT)"}
            ]
        },
        "ai_model": {
            "type": "select",
            "label": "Modello AI",
            "description": "Modello AI per questo modulo",
            "default": "global",
            "admin_only": true,
            "group": "ai_config",
            "options": [
                {"value": "global", "label": "Usa impostazione globale"}
            ]
        },
        "ai_fallback_enabled": {
            "type": "select",
            "label": "Fallback AI",
            "description": "Fallback automatico su altro provider se il primario fallisce",
            "default": "global",
            "admin_only": true,
            "group": "ai_config",
            "options": [
                {"value": "global", "label": "Usa impostazione globale"},
                {"value": "1", "label": "Abilitato"},
                {"value": "0", "label": "Disabilitato"}
            ]
        },
        "default_language": {
            "type": "select",
            "label": "Lingua default",
            "description": "Lingua predefinita per i contenuti generati",
            "options": ["it", "en", "es", "de", "fr"],
            "default": "it",
            "group": "general"
        },
        "default_tone": {
            "type": "select",
            "label": "Tono default",
            "description": "Tono predefinito per i contenuti generati",
            "default": "professionale",
            "group": "general",
            "options": [
                {"value": "professionale", "label": "Professionale"},
                {"value": "informativo", "label": "Informativo"},
                {"value": "tecnico", "label": "Tecnico"},
                {"value": "commerciale", "label": "Commerciale"},
                {"value": "persuasivo", "label": "Persuasivo"}
            ]
        },
        "min_words_product": {
            "type": "number",
            "label": "Prodotto - Min parole",
            "description": "Parole minime per descrizione prodotto",
            "default": 300,
            "min": 100,
            "max": 2000,
            "group": "content_length"
        },
        "min_words_category": {
            "type": "number",
            "label": "Categoria - Min parole",
            "description": "Parole minime per descrizione categoria",
            "default": 400,
            "min": 100,
            "max": 2000,
            "group": "content_length"
        },
        "min_words_article": {
            "type": "number",
            "label": "Articolo - Min parole",
            "description": "Parole minime per articolo/blog post",
            "default": 800,
            "min": 200,
            "max": 5000,
            "group": "content_length"
        },
        "min_words_service": {
            "type": "number",
            "label": "Servizio - Min parole",
            "description": "Parole minime per pagina servizio",
            "default": 500,
            "min": 100,
            "max": 3000,
            "group": "content_length"
        },
        "min_words_default": {
            "type": "number",
            "label": "Custom/Default - Min parole",
            "description": "Parole minime per tipo custom o non specificato",
            "default": 300,
            "min": 100,
            "max": 2000,
            "group": "content_length"
        },
        "image_provider": {
            "type": "select",
            "label": "Provider Immagini",
            "description": "Provider AI per la generazione immagini",
            "default": "gemini",
            "group": "image_config",
            "options": {"gemini": "Google Gemini"}
        },
        "image_model": {
            "type": "text",
            "label": "Modello Immagini",
            "description": "Modello Gemini per image-to-image",
            "default": "gemini-2.0-flash-exp",
            "group": "image_config"
        },
        "default_variants_count": {
            "type": "number",
            "label": "Varianti per generazione",
            "description": "Numero di varianti generate per ogni richiesta",
            "default": 3,
            "min": 1,
            "max": 4,
            "group": "image_config"
        },
        "default_scene_type": {
            "type": "select",
            "label": "Tipo scena default",
            "description": "Tipo di scena predefinito per la generazione",
            "default": "fashion",
            "group": "image_config",
            "options": {"fashion": "Fashion (try-on)", "home": "Home/Lifestyle (staging)"}
        },
        "default_gender": {
            "type": "select",
            "label": "Genere modello default",
            "description": "Genere predefinito per virtual try-on",
            "default": "woman",
            "group": "image_config",
            "options": {"woman": "Donna", "man": "Uomo", "neutral": "Neutro"}
        },
        "default_background": {
            "type": "select",
            "label": "Sfondo default",
            "description": "Sfondo predefinito per le immagini generate",
            "default": "studio_white",
            "group": "image_config",
            "options": {"studio_white": "Studio bianco", "urban": "Urbano", "lifestyle": "Lifestyle", "nature": "Natura"}
        },
        "default_environment": {
            "type": "select",
            "label": "Ambiente default",
            "description": "Ambiente predefinito per home staging",
            "default": "living_room",
            "group": "image_config",
            "options": {"living_room": "Soggiorno", "kitchen": "Cucina", "bedroom": "Camera", "office": "Ufficio", "outdoor": "Esterno"}
        },
        "default_photo_style": {
            "type": "select",
            "label": "Stile foto default",
            "description": "Stile fotografico predefinito",
            "default": "professional",
            "group": "image_config",
            "options": {"professional": "Professional catalog", "editorial": "Editorial magazine", "minimal": "Minimal clean"}
        },
        "image_push_mode": {
            "type": "select",
            "label": "Modalità push immagine",
            "description": "Come inserire le immagini generate nel CMS",
            "default": "add_as_gallery",
            "group": "image_config",
            "options": {"add_as_gallery": "Aggiungi in galleria", "replace_main": "Sostituisci principale", "add": "Aggiungi"}
        },
        "image_output_format": {
            "type": "select",
            "label": "Formato output",
            "description": "Formato delle immagini generate",
            "default": "webp",
            "group": "image_config",
            "options": {"webp": "WebP", "jpeg": "JPEG", "png": "PNG"}
        },
        "image_output_quality": {
            "type": "number",
            "label": "Qualità output",
            "description": "Qualità di compressione delle immagini (60-100)",
            "default": 85,
            "min": 60,
            "max": 100,
            "group": "image_config"
        },
        "image_cleanup_days": {
            "type": "number",
            "label": "Retention varianti rifiutate (giorni)",
            "description": "Giorni di conservazione delle varianti rifiutate prima della pulizia automatica",
            "default": 30,
            "group": "image_config"
        },
        "cost_scrape_url": {
            "type": "number",
            "label": "Costo Scraping per URL",
            "description": "Crediti per scraping contenuto pagina (opzionale)",
            "default": 1,
            "min": 0,
            "step": 0.1,
            "admin_only": true,
            "group": "costs"
        },
        "cost_ai_generate": {
            "type": "number",
            "label": "Costo Generazione AI per URL",
            "description": "Crediti per generazione contenuto HTML completo",
            "default": 3,
            "min": 0,
            "step": 0.1,
            "admin_only": true,
            "group": "costs"
        },
        "cost_image_generate": {
            "type": "number",
            "label": "Costo Generazione Immagine (per variante)",
            "description": "Crediti consumati per ogni variante immagine generata",
            "default": 2,
            "min": 0,
            "step": 0.1,
            "admin_only": true,
            "group": "costs"
        }
    }
}
